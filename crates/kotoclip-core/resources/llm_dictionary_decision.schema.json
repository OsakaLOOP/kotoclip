{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "request_id",
    "status",
    "selected_candidate_id",
    "ranked_candidate_ids",
    "confidence",
    "needs_user_review",
    "summary",
    "ambiguity_reason",
    "evidence",
    "navigation_recommendation"
  ],
  "properties": {
    "schema_version": { "const": "kotoclip.dictionary-disambiguation.v1" },
    "request_id": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["selected", "ambiguous", "insufficient_evidence"]
    },
    "selected_candidate_id": { "type": ["string", "null"] },
    "ranked_candidate_ids": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "needs_user_review": { "type": "boolean" },
    "summary": { "type": "string", "maxLength": 500 },
    "ambiguity_reason": { "type": ["string", "null"], "maxLength": 500 },
    "evidence": {
      "type": "array",
      "maxItems": 12,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["candidate_id", "context_quote", "definition_quote", "supports"],
        "properties": {
          "candidate_id": { "type": "string" },
          "context_quote": { "type": "string", "minLength": 1, "maxLength": 300 },
          "definition_quote": { "type": "string", "minLength": 1, "maxLength": 300 },
          "supports": { "type": "string", "maxLength": 300 }
        }
      }
    },
    "navigation_recommendation": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["from_candidate_id", "relation", "target", "target_candidate_id", "context_quote", "target_content_quote", "reason"],
      "properties": {
        "from_candidate_id": { "type": "string" },
        "relation": { "type": "string" },
        "target": { "type": "string" },
        "target_candidate_id": { "type": "string" },
        "context_quote": { "type": "string", "minLength": 1, "maxLength": 300 },
        "target_content_quote": { "type": "string", "minLength": 1, "maxLength": 300 },
        "reason": { "type": "string", "maxLength": 300 }
      }
    }
  }
}
