{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kotoclip",
  "version": "0.1.0",
  "identifier": "com.kotoclip.app",
  "build": {
    "beforeDevCommand": "npm run frontend:dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Kotoclip",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; connect-src 'self' ipc: http://ipc.localhost; img-src 'self' data: asset:; style-src 'self' 'unsafe-inline'; script-src 'self'",
      "assetProtocol": {
        "enable": true,
        "scope": ["$TEMP/kotoclip-reader/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "../ipadic/system.dic",
      "../data/dict-sources/starter.kdict",
      "../data/dict-sources/daijirin.kdict",
      "../data/dict-sources/shogakukan.kdict",
      "../data/dict-sources/crown.kdict"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
